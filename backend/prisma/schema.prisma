// Role values: SuperAdmin | orgAdmin | member (SQLite stores as String)

generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}
model Organization {
  id        String   @id @default(uuid())
  name      String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  blogs     Blog[]
  events    Event[]
  users     User[]

  @@map("organizations")
}

model User {
  id                 Int           @id @default(autoincrement())
  name               String
  email              String        @unique
  phone              String?
  role               String        @default("orgAdmin")
  organizationId     String?
  organization_name  String?
  organization_type  String?
  password           String
  profile_photo_path String?
  email_verified_at  DateTime?
  google_id          String?
  sex                String?
  join_date          DateTime?
  address            String?
  plan_id            Int?
  plan_expiry        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  members            Member[]
  payments           Payment[]
  notifications      Notification[]
  plan               Plan?         @relation(fields: [plan_id], references: [id])
  organization       Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  blogs                Blog[]        @relation("BlogAuthor")

  @@map("users")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model Member {
  id          Int       @id @default(autoincrement())
  name        String
  email       String    @unique
  role        String?
  status      String?
  join_date   DateTime?
  last_active DateTime?
  photo       String?
  user_id     Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [user_id], references: [id])

  @@map("members")
}

model Plan {
  id            Int       @id @default(autoincrement())
  name          String
  price         Float
  billing_cycle String
  type          String
  max_members   Int
  duration_days Int
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  payments      Payment[]
  users         User[]

  @@map("plans")
}

model Payment {
  id             Int      @id @default(autoincrement())
  user_id        Int
  plan_id        Int
  amount         Float
  payment_method String
  status         String
  transaction_id String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  plan           Plan     @relation(fields: [plan_id], references: [id])
  user           User     @relation(fields: [user_id], references: [id])

  @@map("payments")
}

model Blog {
  id             Int           @id @default(autoincrement())
  title          String
  content        String
  image          String?
  status         String        @default("draft")
  category       String        @default("general")
  author_id      Int
  author         User          @relation("BlogAuthor", fields: [author_id], references: [id])

  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organizations  Organization? @relation(fields: [organizationId], references: [id])

  @@map("blogs")
}

model Event {
  id             Int           @id @default(autoincrement())
  title          String
  description    String
  date           DateTime
  location       String?
  image          String?
  status         String        @default("draft")
  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organizations  Organization? @relation(fields: [organizationId], references: [id])

  @@map("events")
}
