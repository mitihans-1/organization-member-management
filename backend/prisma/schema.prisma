// Role values: SuperAdmin | orgAdmin | member

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Organization {
  id               String                      @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  type             String
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  blogs            Blog[]
  events           Event[]
  users            User[]
  customAttributes CustomAttributeDefinition[]
  plan_id          String?                     @db.ObjectId
  plan_expiry      DateTime?
  plan             Plan?                       @relation(fields: [plan_id], references: [id])
  payment_phone    String?

  @@map("organizations")
}

model User {
  id                    String                 @id @default(auto()) @map("_id") @db.ObjectId
  name                  String
  email                 String                 @unique
  phone                 String?
  role                  String                 @default("orgAdmin")
  organizationId        String?                @db.ObjectId
  organization_name     String?
  organization_type     String?
  password              String
  profile_photo_path    String?
  email_verified_at     DateTime?
  google_id             String?
  sex                   String?
  join_date             DateTime?
  address               String?
  plan_id               String?                @db.ObjectId
  plan_expiry           DateTime?
  fayda_id              String?
  is_fayda_verified     Boolean                @default(false)
  is_verified           Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  members               Member[]
  payments              Payment[]
  notifications         Notification[]
  otpTokens             OtpToken[]
  customAttributeValues MemberAttributeValue[]
  plan                  Plan?                  @relation(fields: [plan_id], references: [id])
  organization          Organization?          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  blogs                 Blog[]                 @relation("BlogAuthor")
  
  attendedEventsIds     String[]               @db.ObjectId
  attendedEvents        Event[]                @relation("EventAttendees", fields: [attendedEventsIds], references: [id])

  @@map("users")
}

model CustomAttributeDefinition {
  id             String                 @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  type           String                 // "text", "number", "date", "boolean"
  required       Boolean                @default(false)
  organizationId String                 @db.ObjectId
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  values         MemberAttributeValue[]

  @@map("custom_attribute_definitions")
}

model MemberAttributeValue {
  id          String                    @id @default(auto()) @map("_id") @db.ObjectId
  memberId    String                    @db.ObjectId
  attributeId String                    @db.ObjectId
  value       String
  member      User                      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  attribute   CustomAttributeDefinition @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([memberId, attributeId])
  @@map("member_attribute_values")
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  title     String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model PasswordResetToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model OtpToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  otp_code  String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_tokens")
}

model Member {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String    @unique
  role        String?
  status      String?
  join_date   DateTime?
  last_active DateTime?
  photo       String?
  user_id     String    @db.ObjectId
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [user_id], references: [id])

  @@map("members")
}

model Plan {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  price         Float
  billing_cycle String
  type          String
  max_members   Int
  duration_days Int
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  payments      Payment[]
  users         User[]
  organizations Organization[]

  @@map("plans")
}

model Payment {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  user_id          String   @db.ObjectId
  plan_id          String?  @db.ObjectId
  amount           Float
  payment_method   String
  status           String
  transaction_id   String?
  receipt_url      String?
  rejection_reason String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  plan             Plan?    @relation(fields: [plan_id], references: [id])
  user             User     @relation(fields: [user_id], references: [id])

  payer_type       String?
  payer_id         String?
  payee_type       String?
  payee_id         String?
  reference_type   String?
  reference_id     String?

  organization_id  String?  @db.ObjectId

  @@map("payments")
}

model Blog {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  content        String
  image          String?
  status         String        @default("draft")
  category       String        @default("general")
  tags           String?
  readTime       Int?
  author_id      String        @db.ObjectId
  author         User          @relation("BlogAuthor", fields: [author_id], references: [id])

  organizationId String?       @db.ObjectId
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organizations  Organization? @relation(fields: [organizationId], references: [id])
  price          Float?
  payment_required Boolean    @default(false)

  @@map("blogs")
}

model Event {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  description    String
  date           DateTime
  end_date       DateTime?
  location       String?
  image          String?
  status         String        @default("draft")
  category       String        @default("general")
  capacity       Int?
  virtualLink    String?
  contactEmail   String?
  organizationId String?       @db.ObjectId
  price          Float?
  payment_required Boolean    @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organizations  Organization? @relation(fields: [organizationId], references: [id])

  attendeesIds   String[]      @db.ObjectId
  attendees      User[]        @relation("EventAttendees", fields: [attendeesIds], references: [id])

  @@map("events")
}
